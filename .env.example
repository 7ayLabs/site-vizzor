# site-vizzor — environment variable registry.
#
# Copy to `.env.local` for local development. Production deployments
# inject these via the operator's managed secret store (Doppler /
# Infisical / 1Password CLI — see docs/ops/secrets.md). Every required
# variable is marked `# REQUIRED in prod`. Defaults are safe for dev.
#
# Environment mapping (per BRANCHING.md §10):
#
#   main    → vizzor.ai          mainnet     /opt/7aylabs/.env
#   testing → test.vizzor.ai     devnet      /opt/7aylabs/.env.staging
#
# Staging override summary — these are the variables whose values
# differ between prod and staging on the VPS:
#
#   NEXT_PUBLIC_PAYMENT_NETWORK=devnet                (staging only)
#   SOLANA_RPC_URL_DEVNET=https://api.devnet.solana.com  (staging primary RPC)
#   VIZZOR_SOLANA_TREASURY_DEVNET=…                   (separate from prod)
#   VIZZOR_BOT_SHARED_SECRET=…                        (separate value)
#   NEXT_PUBLIC_TG_BOT_USERNAME=vizzorai_test_bot     (separate bot)
#   VIZZOR_RATE_LIMIT_SALT=…                          (separate value)
#   VIZZOR_EXTRA_ORIGINS=https://test.vizzor.ai       (allows staging origin)
#
# Everything else is identical to prod — same upstream engine
# (api.vizzor.ai), same code paths, same security middleware. Staging
# always runs NODE_ENV=production so security headers, __Host- cookies,
# and fail-closed env checks behave identically.

# ──────────────────────────── Build metadata ────────────────────────────

GIT_SHA=local-dev
BUILD_TIME=

# ──────────────────────────── Upstream engine ───────────────────────────

VIZZOR_API_URL=http://localhost:7100
NEXT_PUBLIC_VIZZOR_API_URL=http://localhost:7100

# The engine validates an X-API-Key header on every request (see
# `vizzor/src/api/auth/middleware.ts`). Mint a key on the engine
# (`pnpm exec vizzor api key create site`) and paste it here. The site
# uses this single service-account key for both `/api/predict` (chat
# streaming) and `/api/snapshot` (hourly cron). Without it the engine
# returns 401 and the chat shows "Vizzor offline".
VIZZOR_API_KEY=

# ──────────────────────────── Predict quota ────────────────────────────

NEXT_PUBLIC_FREE_PREDICTIONS=7

# ──────────────────────────── Payment feature flag ─────────────────────

# Plan-payment kill switch. Default off; flip to true once the treasury
# is provisioned, the dedicated RPC is set, and the watcher has been
# validated. The /pay/* shell renders an "infrastructure pending"
# panel until this is true.
NEXT_PUBLIC_ACCEPT_SOLANA_PAYMENTS=false

# USD-to-token rate lock window in seconds (60-3600). The session
# expires past this if the user hasn't paid.
NEXT_PUBLIC_PAYMENT_RATE_LOCK_SECONDS=300

# ──────────────────────────── Payment network ──────────────────────────

# Auto-resolves to `mainnet` in production, `testnet` when
# NODE_ENV=test, and `devnet` everywhere else (including local dev).
# Set explicitly to override.
# NEXT_PUBLIC_PAYMENT_NETWORK=mainnet

# ──────────────────────────── Dev auth bypass ──────────────────────────

# `/api/auth/dev-sign` mints an auth session WITHOUT a wallet signature.
# Triple-gated: returns 404 unless ALL of these hold:
#   1. NODE_ENV=development
#   2. NEXT_PUBLIC_ALLOW_DEV_AUTH=true
#   3. Request origin/referer host is `localhost`, `127.0.0.1`, or `::1`
# A "Dev sign-in (skip wallet)" link appears in the wallet modal when
# this flag is set. Use it when Phantom on localhost + multi-chain
# Testnet Mode is rejecting SIWS sign-in with "Unexpected error".
# Never set in staging or production — the route returns 404 there
# regardless, but keeping the flag unset means the UI hint is absent.
# NEXT_PUBLIC_ALLOW_DEV_AUTH=true

# Optional default wallet the bypass uses without prompting. Any valid
# base58 Solana address — typically a throwaway test wallet.
# NEXT_PUBLIC_DEV_WALLET=5oQ2uHV8TFQ1w1cXSotFHdvFiKXQyesuMY2YTLhtb1qL

# ──────────────────────────── Solana RPC ────────────────────────────────

# Generic / shared override (used for whichever network is active).
SOLANA_RPC_URL=
NEXT_PUBLIC_SOLANA_RPC_URL=

# Network-specific overrides — take precedence when set.
SOLANA_RPC_URL_MAINNET=
NEXT_PUBLIC_SOLANA_RPC_URL_MAINNET=
SOLANA_RPC_URL_TESTNET=
NEXT_PUBLIC_SOLANA_RPC_URL_TESTNET=
SOLANA_RPC_URL_DEVNET=
NEXT_PUBLIC_SOLANA_RPC_URL_DEVNET=

# Fallback chain when nothing is configured:
#   mainnet → https://solana-rpc.publicnode.com (browser-CORS-friendly)
#   testnet → https://api.devnet.solana.com     (devnet public default)
#
# REQUIRED in prod mainnet — getRpc() throws if missing in production
# when paymentNetwork() === 'mainnet'.

# ──────────────────────────── Solana treasury ──────────────────────────

# Mainnet — pre-screened against OFAC SDN before deploy.
VIZZOR_SOLANA_TREASURY_MAINNET=
# Testnet (Solana testnet cluster) — throwaway address.
VIZZOR_SOLANA_TREASURY_TESTNET=11111111111111111111111111111111
# Devnet (Solana devnet cluster, faucet enabled) — throwaway address.
VIZZOR_SOLANA_TREASURY_DEVNET=11111111111111111111111111111111
# Legacy single var (treated as mainnet). Use the _MAINNET variant in
# new deployments.
VIZZOR_SOLANA_TREASURY=

# ──────────────────────────── TON treasury ─────────────────────────────

# Mainnet (friendly address starts with 'E' or 'U').
VIZZOR_TON_TREASURY_MAINNET=
# Testnet (friendly address starts with 'k' or '0').
VIZZOR_TON_TREASURY_TESTNET=
# Legacy single var.
VIZZOR_TON_TREASURY=

# ──────────────────────────── EVM treasuries ───────────────────────────

VIZZOR_EVM_TREASURY_BASE_MAINNET=
VIZZOR_EVM_TREASURY_BASE_TESTNET=
VIZZOR_EVM_TREASURY_BASE=

VIZZOR_EVM_TREASURY_ARB_MAINNET=
VIZZOR_EVM_TREASURY_ARB_TESTNET=
VIZZOR_EVM_TREASURY_ARB=

# ──────────────────────────── Rate dev mocks ───────────────────────────

# Bypass the CoinGecko fetch so local dev doesn't depend on network
# availability. Unset in prod.
NEXT_PUBLIC_SOL_MOCK_USD=
NEXT_PUBLIC_TON_MOCK_USD=
NEXT_PUBLIC_USDC_MOCK_USD=

# ──────────────────────────── Telegram bot transport ─────────────────

# Bot ↔ site shared secret (32 random bytes base64url-encoded). All
# bot routes (/api/grants/[code]/redeem, /api/subscriptions/lookup,
# /api/wallet-links{,/challenge}) require this in the
# x-vizzor-bot-token header. Production returns 503 if unset.
# REQUIRED in prod.
VIZZOR_BOT_SHARED_SECRET=

# Rotation window: set both the current and next secret while you
# redeploy the bot, then drop the old one. See docs/ops/secrets.md.
VIZZOR_BOT_SHARED_SECRET_NEXT=

# Telegram bot username (without the @). Used by the grant-handoff
# deep-link: t.me/<username>?start=g_<code>.
NEXT_PUBLIC_TG_BOT_USERNAME=vizzorai_bot

# ──────────────────────────── SQLite ──────────────────────────────────

# Site-owned database path. Production mounts a named Docker volume
# at this path so subscriptions / sessions / grants / wallet_links
# survive container restarts.
VIZZOR_SITE_DB=.vizzor/site.db

# ──────────────────────────── Observability (optional) ───────────────

# Structured-logging Sentry DSN. When unset, errors print to stderr
# without remote reporting. Cookie / signature values are redacted at
# the integration layer before being sent.
VIZZOR_SENTRY_DSN=

# ──────────────────────────── v0.2.x security pass ───────────────────

# REQUIRED in production. HMAC salt for hashing client IPs before
# they're used as a rate-limit bucket key. Generate with:
#   `node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"`
# The salt itself is never logged; rotating it invalidates the daily
# rate-limit buckets, which the sweep reclaims within 24h.
VIZZOR_RATE_LIMIT_SALT=

# Optional. Cap on the persistent signature_replay_cache table — the
# watcher's defense against reorg-induced double-credit. 4096 covers
# >24h at our current confirmation volume; raise if the watcher floor
# climbs.
VIZZOR_REPLAY_CACHE_SIZE=4096

# Optional. USD-cents threshold above which the watcher waits for
# Solana `finalized` commitment (reorg-proof, ~13s) instead of the
# faster `confirmed` (~400ms). Default 10000 ($100). Lifetime tier
# ($1,499) is always finalized at the default; monthly Pro stays on
# the confirmed path.
VIZZOR_FINALIZED_USD_THRESHOLD=10000

# Optional retention overrides (in days).
# VIZZOR_RETENTION_DAYS_FAILED_SESSIONS=30
# VIZZOR_RETENTION_DAYS_CONFIRMED=365
# VIZZOR_RETENTION_DAYS_GRANTS=90
# VIZZOR_RETENTION_DAYS_AUDIT=365

# Optional. Comma-separated list of extra origins to accept on
# mutating routes — useful for staging URLs or short-lived preview
# environments. Production origins (`https://vizzor.ai`,
# `https://www.vizzor.ai`) are baked into the check.
# VIZZOR_EXTRA_ORIGINS=https://staging.vizzor.ai
