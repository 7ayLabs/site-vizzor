# site-vizzor — environment variable registry.
#
# Copy to `.env.local` for local development. Production deployments
# inject these via the operator's managed secret store (Doppler /
# Infisical / 1Password CLI — see docs/ops/secrets.md). Every required
# variable is marked `# REQUIRED in prod`. Defaults are safe for dev.
#
# v0.2.0 introduces the multi-chain plan-payment surface (TON + Solana
# + Base + Arbitrum USDC) plus the Telegram-binding bot transport. The
# new variables are grouped under their respective slices below.

# ──────────────────────────── Build metadata ────────────────────────────

GIT_SHA=local-dev
BUILD_TIME=

# ──────────────────────────── Upstream engine ───────────────────────────

VIZZOR_API_URL=http://localhost:7100
NEXT_PUBLIC_VIZZOR_API_URL=http://localhost:7100

# ──────────────────────────── Predict quota ────────────────────────────

NEXT_PUBLIC_FREE_PREDICTIONS=3

# ──────────────────────────── Feature flags ────────────────────────────

# $VZR token live (burn-to-predict UI + tiered VIZZOR discount column).
# Reads NEXT_PUBLIC_VZR_LIVE first, falls back to the legacy
# NEXT_PUBLIC_TOKEN_LIVE during the env-var rename window.
NEXT_PUBLIC_VZR_LIVE=false

# Per-rail plan-payment flags. Default off; flip per chain as the
# treasury + RPC are provisioned. The checkout shell renders
# "infrastructure pending" until at least one is true.
NEXT_PUBLIC_ACCEPT_TON_PAYMENTS=false
NEXT_PUBLIC_ACCEPT_VIZZOR_PAYMENTS=false
NEXT_PUBLIC_ACCEPT_USDC_BASE=false
NEXT_PUBLIC_ACCEPT_USDC_ARB=false

# USD-to-token rate lock window in seconds (60-3600). The session
# expires past this if the user hasn't paid.
NEXT_PUBLIC_PAYMENT_RATE_LOCK_SECONDS=300

# ──────────────────────────── Solana ──────────────────────────────────

# Server-side dedicated RPC. Public mainnet-beta is rate-limited and
# unsafe for burn verification under load — Helius / QuickNode / Triton
# / Solana Labs paid tier all work.
# REQUIRED in prod when NEXT_PUBLIC_VZR_LIVE=true OR ACCEPT_VIZZOR_PAYMENTS=true.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Solana treasury wallet (base58). Pre-screened against the OFAC SDN
# list before deploy. The watcher confirms incoming SPL transfers to
# this address by memo match.
# REQUIRED in prod when ACCEPT_VIZZOR_PAYMENTS=true.
VIZZOR_SOLANA_TREASURY=

# $VIZZOR / $VZR SPL token mint address (base58).
# REQUIRED in prod when NEXT_PUBLIC_VZR_LIVE=true.
NEXT_PUBLIC_VIZZOR_MINT=

# Minimum burn amount to unlock a paid prediction (human units).
NEXT_PUBLIC_VIZZOR_BURN_AMOUNT=1

# Mock $VIZZOR USD price for dev/staging. Skipped in prod where the
# engine's /v1/market/price/VIZZOR is the source of truth.
NEXT_PUBLIC_VZR_MOCK_USD=
NEXT_PUBLIC_VIZZOR_MOCK_USD=

# Persistent burn-signature replay cache cap (rows).
VIZZOR_REPLAY_CACHE_SIZE=4096

# Defensive ATA self-test (plan §6.2 / B1). When set, verifyBurnTx
# refuses to start if the locally-derived incinerator ATA does not
# match this value. Defeats supply-chain swaps of @solana/web3.js.
VIZZOR_EXPECTED_INCINERATOR_ATA=

# ──────────────────────────── TON ─────────────────────────────────────

# TON treasury (friendly address — mainnet starts with 'E' or 'U';
# testnet starts with '0' or 'k'). The watcher refuses to start on
# a mainnet/testnet mismatch.
# REQUIRED in prod when ACCEPT_TON_PAYMENTS=true.
VIZZOR_TON_TREASURY=

# Network discriminator. The watcher fails closed if the treasury
# address doesn't match the network.
VIZZOR_TON_NETWORK=mainnet

# TonCenter RPC. Public free tier is rate-limited; set the API key
# to lift the floor or point at a dedicated TonCenter Pro endpoint.
VIZZOR_TON_RPC_URL=https://toncenter.com/api/v2
VIZZOR_TON_RPC_URL_FALLBACK=
VIZZOR_TONCENTER_API_KEY=

# ──────────────────────────── EVM (Base + Arbitrum) ──────────────────

# Per-chain treasury addresses. Canonical USDC contract is hard-coded
# in lib/payment/evm-watcher.ts so a malicious env can't redirect the
# watcher to a fake USDC contract.
# REQUIRED in prod when ACCEPT_USDC_BASE / ACCEPT_USDC_ARB = true.
VIZZOR_EVM_TREASURY_BASE=
VIZZOR_EVM_TREASURY_ARB=

# Per-chain RPC URLs. Default to public endpoints; configure a
# dedicated provider (Alchemy / Infura / Tenderly / Conduit) for prod.
VIZZOR_EVM_RPC_BASE=https://mainnet.base.org
VIZZOR_EVM_RPC_BASE_FALLBACK=
VIZZOR_EVM_RPC_ARB=https://arb1.arbitrum.io/rpc
VIZZOR_EVM_RPC_ARB_FALLBACK=

# ──────────────────────────── Telegram bot transport ─────────────────

# Bot ↔ site shared secret (32 random bytes base64url-encoded). All
# bot routes (/api/grants/[code]/redeem, /api/subscriptions/lookup,
# /api/wallet-links{,/challenge}) require this in the
# x-vizzor-bot-token header. Production returns 503 if unset.
# REQUIRED in prod.
VIZZOR_BOT_SHARED_SECRET=

# Rotation window: set both the current and next secret while you
# redeploy the bot, then drop the old one. See docs/ops/secrets.md.
VIZZOR_BOT_SHARED_SECRET_NEXT=

# Telegram bot username (without the @). Used by the grant-handoff
# deep-link: t.me/<username>?start=g_<code>.
NEXT_PUBLIC_TG_BOT_USERNAME=vizzorai_bot

# ──────────────────────────── SQLite ──────────────────────────────────

# Site-owned database path. Production mounts a named Docker volume
# at this path so subscriptions / sessions / grants / wallet_links
# survive container restarts.
VIZZOR_SITE_DB=.vizzor/site.db

# ──────────────────────────── Treasury custody (deferred) ────────────

# HD-derived per-session addresses. Off by default in v0.2.0 — fixed
# treasury addresses ship in this release. When enabled in v0.2.1+,
# VIZZOR_TREASURY_MNEMONIC MUST come from a managed secret store, not
# plaintext env. See docs/ops/secrets.md.
VIZZOR_HD_DERIVATION_ENABLED=false
VIZZOR_TREASURY_MNEMONIC=

# ──────────────────────────── Observability (optional) ───────────────

# Structured-logging Sentry DSN. When unset, errors print to stderr
# without remote reporting. Cookie / signature values are redacted at
# the integration layer before being sent.
VIZZOR_SENTRY_DSN=
