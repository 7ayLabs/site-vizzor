# site-vizzor — environment variable registry.
#
# Copy to `.env.local` for local development. Production deployments
# inject these via the operator's managed secret store (Doppler /
# Infisical / 1Password CLI — see docs/ops/secrets.md). Every required
# variable is marked `# REQUIRED in prod`. Defaults are safe for dev.

# ──────────────────────────── Build metadata ────────────────────────────

GIT_SHA=local-dev
BUILD_TIME=

# ──────────────────────────── Upstream engine ───────────────────────────

VIZZOR_API_URL=http://localhost:7100
NEXT_PUBLIC_VIZZOR_API_URL=http://localhost:7100

# ──────────────────────────── Predict quota ────────────────────────────

NEXT_PUBLIC_FREE_PREDICTIONS=3

# ──────────────────────────── Payment feature flag ─────────────────────

# Plan-payment kill switch. Default off; flip to true once the treasury
# is provisioned, the dedicated RPC is set, and the watcher has been
# validated. The /pay/* shell renders an "infrastructure pending"
# panel until this is true.
NEXT_PUBLIC_ACCEPT_SOLANA_PAYMENTS=false

# USD-to-token rate lock window in seconds (60-3600). The session
# expires past this if the user hasn't paid.
NEXT_PUBLIC_PAYMENT_RATE_LOCK_SECONDS=300

# ──────────────────────────── Payment network ──────────────────────────

# Auto-resolves to `mainnet` in production, `testnet` when
# NODE_ENV=test, and `devnet` everywhere else (including local dev).
# Set explicitly to override.
# NEXT_PUBLIC_PAYMENT_NETWORK=mainnet

# ──────────────────────────── Solana RPC ────────────────────────────────

# Generic / shared override (used for whichever network is active).
SOLANA_RPC_URL=
NEXT_PUBLIC_SOLANA_RPC_URL=

# Network-specific overrides — take precedence when set.
SOLANA_RPC_URL_MAINNET=
NEXT_PUBLIC_SOLANA_RPC_URL_MAINNET=
SOLANA_RPC_URL_TESTNET=
NEXT_PUBLIC_SOLANA_RPC_URL_TESTNET=
SOLANA_RPC_URL_DEVNET=
NEXT_PUBLIC_SOLANA_RPC_URL_DEVNET=

# Fallback chain when nothing is configured:
#   mainnet → https://solana-rpc.publicnode.com (browser-CORS-friendly)
#   testnet → https://api.devnet.solana.com     (devnet public default)
#
# REQUIRED in prod mainnet — getRpc() throws if missing in production
# when paymentNetwork() === 'mainnet'.

# ──────────────────────────── Solana treasury ──────────────────────────

# Mainnet — pre-screened against OFAC SDN before deploy.
VIZZOR_SOLANA_TREASURY_MAINNET=
# Testnet (Solana testnet cluster) — throwaway address.
VIZZOR_SOLANA_TREASURY_TESTNET=11111111111111111111111111111111
# Devnet (Solana devnet cluster, faucet enabled) — throwaway address.
VIZZOR_SOLANA_TREASURY_DEVNET=11111111111111111111111111111111
# Legacy single var (treated as mainnet). Use the _MAINNET variant in
# new deployments.
VIZZOR_SOLANA_TREASURY=

# ──────────────────────────── TON treasury ─────────────────────────────

# Mainnet (friendly address starts with 'E' or 'U').
VIZZOR_TON_TREASURY_MAINNET=
# Testnet (friendly address starts with 'k' or '0').
VIZZOR_TON_TREASURY_TESTNET=
# Legacy single var.
VIZZOR_TON_TREASURY=

# ──────────────────────────── EVM treasuries ───────────────────────────

VIZZOR_EVM_TREASURY_BASE_MAINNET=
VIZZOR_EVM_TREASURY_BASE_TESTNET=
VIZZOR_EVM_TREASURY_BASE=

VIZZOR_EVM_TREASURY_ARB_MAINNET=
VIZZOR_EVM_TREASURY_ARB_TESTNET=
VIZZOR_EVM_TREASURY_ARB=

# ──────────────────────────── Rate dev mocks ───────────────────────────

# Bypass the CoinGecko fetch so local dev doesn't depend on network
# availability. Unset in prod.
NEXT_PUBLIC_SOL_MOCK_USD=
NEXT_PUBLIC_TON_MOCK_USD=
NEXT_PUBLIC_USDC_MOCK_USD=

# ──────────────────────────── Telegram bot transport ─────────────────

# Bot ↔ site shared secret (32 random bytes base64url-encoded). All
# bot routes (/api/grants/[code]/redeem, /api/subscriptions/lookup,
# /api/wallet-links{,/challenge}) require this in the
# x-vizzor-bot-token header. Production returns 503 if unset.
# REQUIRED in prod.
VIZZOR_BOT_SHARED_SECRET=

# Rotation window: set both the current and next secret while you
# redeploy the bot, then drop the old one. See docs/ops/secrets.md.
VIZZOR_BOT_SHARED_SECRET_NEXT=

# Telegram bot username (without the @). Used by the grant-handoff
# deep-link: t.me/<username>?start=g_<code>.
NEXT_PUBLIC_TG_BOT_USERNAME=vizzorai_bot

# ──────────────────────────── SQLite ──────────────────────────────────

# Site-owned database path. Production mounts a named Docker volume
# at this path so subscriptions / sessions / grants / wallet_links
# survive container restarts.
VIZZOR_SITE_DB=.vizzor/site.db

# ──────────────────────────── Observability (optional) ───────────────

# Structured-logging Sentry DSN. When unset, errors print to stderr
# without remote reporting. Cookie / signature values are redacted at
# the integration layer before being sent.
VIZZOR_SENTRY_DSN=
